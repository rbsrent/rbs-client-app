{
  "expo": {
    "name": "Аренда яхт",
    "slug": "rbs-client-app",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-rbs.png",
    "scheme": "rbsrent",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon-rbs.png",
      "bundleIdentifier": "com.rbsrent.app",
      "buildNumber": "2",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.rbsrent.app",
      "versionCode": 2,
      "minSdkVersion": 26,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withYamapFix",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Приложение использует геолокацию для отображения вашего положения на карте причалов."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
