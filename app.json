{
  "expo": {
    "name": "RBS Аренда яхт и катеров",
    "slug": "rbs-client-app",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-rbs.png",
    "scheme": "rbsrent",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon-rbs.png",
      "bundleIdentifier": "com.rbsrent.app",
      "buildNumber": "2",
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "api.rbs.rent": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionMinimumTLSVersion": "TLSv1.0",
              "NSExceptionRequiresForwardSecrecy": false
            }
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "navigationBar": {
        "backgroundColor": "#00000000",
        "barStyle": "dark-content"
      },
      "package": "com.rbsrent.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 2,
      "minSdkVersion": 26,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withYamapFix",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RBS использует ваше местоположение, чтобы показать вас на карте причалов и помочь найти ближайшую точку отправления."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon-rbs.png",
          "color": "#208AEF",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b72fc346-7562-4433-b62a-3b370ad1ae32"
      }
    },
    "owner": "rbsrent"
  }
}
