{
  "expo": {
    "name": "RBS Аренда яхт и катеров",
    "slug": "rbs-client-app",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-rbs.png",
    "scheme": "rbsrent",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon-rbs.png",
      "bundleIdentifier": "com.rbsrent.app",
      "buildNumber": "2",
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:rbs.rent",
        "applinks:rbs.rent"
      ],
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "api.rbs.rent": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionMinimumTLSVersion": "TLSv1.0",
              "NSExceptionRequiresForwardSecrecy": false
            },
            "proxy.rbs.rent": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionMinimumTLSVersion": "TLSv1.0",
              "NSExceptionRequiresForwardSecrecy": false
            }
          }
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/play_store_512.png",
        "backgroundColor": "#0D1421"
      },
      "predictiveBackGestureEnabled": false,
      "navigationBar": {
        "backgroundColor": "#00000000",
        "barStyle": "dark-content"
      },
      "package": "com.rbsrent.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 2,
      "minSdkVersion": 26,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "rbs.rent",
              "pathPrefix": "/catalog"
            },
            {
              "scheme": "https",
              "host": "rbs.rent",
              "pathPrefix": "/routes"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RBS использует ваше местоположение, чтобы показать вас на карте причалов и помочь найти ближайшую точку отправления."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D1421",
          "image": "./assets/images/icon-rbs.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "android": {
            "image": "./assets/images/icon-rbs.png",
            "imageWidth": 160
          }
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#208AEF",
          "sounds": []
        }
      ],
      "expo-video",
      [
        "expo-status-bar",
        {
          "style": "dark",
          "backgroundColor": "#00000000",
          "translucent": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b72fc346-7562-4433-b62a-3b370ad1ae32"
      }
    },
    "owner": "rbsrent"
  }
}
